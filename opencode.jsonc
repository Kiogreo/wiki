{
  "$schema": "https://opencode.ai/config.json",
  "theme": "matrix",
  "model": "anthropic/claude-sonnet-4-5",
  "autoupdate": true,
  "mcp": {
    "github": {
      "enabled": true,
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp",
    },
    "context7": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "ctx7sk-254dc844-29b2-4724-9b64-a070158438a3"
      }
    },
    "chrome-devtools": {
      "enabled": true,
      "type": "local",
      "command": ["npx", "chrome-devtools-mcp@latest"],
    },
  },
}
