# opencode configuration
OPENCODE_ENABLE_EXA=1
OPENCODE_EXPERIMENTAL=0

# llm provider - set the API key for your preferred model
# (configured model in opencode.jsonc determines which is used)
ANTHROPIC_API_KEY="your_api_key"
GEMINI_API_KEY="your_api_key"
OLLAMA_API_KEY="your_api_key"

# mcp integrations (optional - enables GitHub & Context7 features)
GITHUB_PERSONAL_ACCESS_TOKEN="your_api_key"
CONTEXT7_API_KEY="your_api_key"
